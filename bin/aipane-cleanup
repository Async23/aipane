#!/bin/sh
# aipane-cleanup: kill detached AI CLI processes + orphaned rod Chromium processes
# Designed to run standalone (e.g. via launchd). POSIX sh compatible.

LOG_PREFIX="aipane-cleanup"
LOG_FILE="${HOME}/logs/aipane-cleanup.log"
mkdir -p "$(dirname "$LOG_FILE")"

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $LOG_PREFIX: $*" >> "$LOG_FILE"
}

kill_gracefully() {
  kill $* 2>/dev/null || true
  sleep 1
  local survivors=""
  for pid in $*; do
    if kill -0 "$pid" 2>/dev/null; then
      survivors="$survivors $pid"
    fi
  done
  if [ -n "$survivors" ]; then
    log "forcing remaining process(es):$survivors"
    kill -9 $survivors 2>/dev/null || true
  fi
}

# --- 1. Detached AI CLI processes (TTY=??) ---
ai_pids=$(ps -axo pid=,tty=,command= | awk '$2 == "??" && ($0 ~ /claude/ || $0 ~ /claude-code/ || $0 ~ /claude-guard/ || $0 ~ /codex/ || $0 ~ /\/droid/ || $0 ~ /factory-droid/ || $0 ~ /gemini/) { print $1 }')

ai_count=0
if [ -n "$ai_pids" ]; then
  ai_count=$(echo "$ai_pids" | wc -l | tr -d ' ')
  log "killing $ai_count detached AI CLI process(es): $(echo $ai_pids | tr '\n' ' ')"
  kill_gracefully $ai_pids
fi

# --- 2. Orphaned rod Chromium processes (PPID=1) ---
rod_pids=$(ps -axo pid=,ppid=,command= | awk '$2 == 1 && $0 ~ /\.cache\/rod\/browser\/.*Chromium/ { print $1 }')

rod_count=0
if [ -n "$rod_pids" ]; then
  rod_count=$(echo "$rod_pids" | wc -l | tr -d ' ')
  log "killing $rod_count orphaned rod Chromium process(es): $(echo $rod_pids | tr '\n' ' ')"
  kill_gracefully $rod_pids
fi

# --- 3. Clean up stale rod user-data dirs ---
ROD_TMP="/var/folders/np/mhwdd58141xflc0rkw1_rc0h0000gn/T/rod/user-data"
if [ -d "$ROD_TMP" ]; then
  count=$(ls -1 "$ROD_TMP" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$count" -gt 0 ] 2>/dev/null; then
    rm -rf "$ROD_TMP"
    log "cleaned up ${count} stale rod user-data dir(s)"
  fi
fi

# --- Summary ---
total=$((ai_count + rod_count))
if [ "$total" -gt 0 ]; then
  log "cleaned up ${total} total process(es)"
else
  log "no orphaned processes found"
fi
